---
const roles = [
  { title: 'Chief of Staff', color: 'coral' },
  { title: 'Customer Success Lead', color: 'teal' },
  { title: 'Director of Operations', color: 'gold' },
  { title: 'Fundraising & Development Lead', color: 'violet' },
  { title: 'Head of Partnerships', color: 'coral' },
  { title: 'Managing Producer', color: 'teal' },
  { title: 'Program Manager', color: 'gold' },
  { title: 'Strategic Account Manager', color: 'violet' },
]

const colorMap: Record<string, { bg: string; text: string; border: string }> = {
  coral: { bg: 'bg-coral-light', text: 'text-coral', border: 'border-coral/30' },
  teal: { bg: 'bg-teal-light', text: 'text-teal', border: 'border-teal/30' },
  gold: { bg: 'bg-gold-light', text: 'text-gold', border: 'border-gold/30' },
  violet: { bg: 'bg-violet-light', text: 'text-violet', border: 'border-violet/30' },
}
---

<section class="py-24 md:py-32 border-t border-base-200">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16">
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-1">
          <span class="w-4 h-4 md:w-3 md:h-3 rounded-sm bg-violet rotate-45"></span>
          <p class="text-base md:text-sm font-medium tracking-widest uppercase text-base-400">Roles</p>
        </div>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-serif text-3xl md:text-4xl font-medium text-base-900 leading-snug tracking-tight">
          Ways I can work with your team.
        </h2>
        <p class="mt-4 text-base-500 text-[17px] leading-relaxed max-w-xl">
          Titles matter less than the through-lines of the work: connecting, motivating,
          and resourcing ideas and people; developing environments that prioritize pluralism, relationships, and
          sustainability; and translating creativity, mission, and vision into pro-social
          artworks, products, and services.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          {roles.map((role) => {
            const c = colorMap[role.color]
            return (
              <span class={`px-5 py-2.5 rounded-xl border ${c.border} ${c.bg} ${c.text} text-sm font-medium`}>
                {role.title}
              </span>
            )
          })}
        </div>
      </div>
    </div>
  </div>
</section>
