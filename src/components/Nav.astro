---
const links = [
  { label: 'About', href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Contact', href: '#contact' },
]
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-base-50/90 backdrop-blur-sm border-b border-base-200/60">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <span class="flex items-center gap-0.5">
        <span class="w-2 h-2 rounded-full bg-coral"></span>
        <span class="w-2 h-2 rounded-full bg-teal"></span>
        <span class="w-2 h-2 rounded-full bg-gold"></span>
        <span class="w-2 h-2 rounded-full bg-violet"></span>
      </span>
      <span class="font-serif text-lg font-medium text-base-900 tracking-tight">
        Hannah Levinson
      </span>
    </a>
    <div class="hidden sm:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-base-500 hover:text-base-900 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>
