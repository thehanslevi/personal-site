---
// Replace with your Formspree form ID after signing up at https://formspree.io
// Create a form, copy the ID (e.g. "xpzvqkdl"), and paste it below.
const FORMSPREE_ID = 'mnjwlyzz'
---

<section id="contact" class="py-24 md:py-32 border-t border-base-200">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16">
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-1">
          <span class="w-4 h-4 md:w-3 md:h-3 rounded-sm bg-coral rotate-45"></span>
          <p class="text-base md:text-sm font-medium tracking-widest uppercase text-base-400">Contact</p>
        </div>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-serif text-3xl md:text-4xl font-medium text-base-900 leading-snug tracking-tight">
          Your turn.
        </h2>
        <p class="mt-4 text-base-500 text-[17px] leading-relaxed max-w-xl">
          Whether you have a specific project in mind or just want to trade notes on
          shared interests, I'm always glad to make new connections.
        </p>

        <form
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          class="mt-10 space-y-5 max-w-lg"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-base-600 mb-1.5">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl border border-base-200 bg-base-50 text-base-800 text-[15px] placeholder:text-base-400 focus:outline-none focus:border-teal focus:ring-1 focus:ring-teal transition-colors duration-200"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-base-600 mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl border border-base-200 bg-base-50 text-base-800 text-[15px] placeholder:text-base-400 focus:outline-none focus:border-teal focus:ring-1 focus:ring-teal transition-colors duration-200"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-base-600 mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl border border-base-200 bg-base-50 text-base-800 text-[15px] placeholder:text-base-400 focus:outline-none focus:border-teal focus:ring-1 focus:ring-teal transition-colors duration-200 resize-y"
              placeholder="What are you working on? How can I help?"
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex items-center px-6 py-3 bg-base-900 text-base-50 text-sm font-medium rounded-full hover:bg-base-800 active:scale-[0.98] transition-all duration-200"
          >
            Send message
          </button>
        </form>

        <div class="mt-12 pt-8 border-t border-base-200">
          <p class="text-sm font-medium text-base-400 mb-4">Also find me on</p>
          <a
            href="https://www.linkedin.com/in/hrlevinson/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 group"
          >
            <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-teal-light group-hover:bg-teal/10 transition-colors duration-200">
              <svg class="w-4 h-4 text-teal" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            <span class="text-sm text-base-600 group-hover:text-teal transition-colors duration-200">
              linkedin.com/in/hrlevinson
            </span>
          </a>
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-teal-light text-teal">Open to travel</span>
          <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-gold-light text-gold">Full-time</span>
          <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-violet-light text-violet">Fractional</span>
          <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-base-100 text-base-500">Contract</span>
        </div>
      </div>
    </div>
  </div>
</section>
