---

<section id="services" class="py-24 md:py-32 bg-stone-100/50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16 mb-16 md:mb-20">
      <div class="md:col-span-4">
        <p class="text-sm font-medium tracking-widest uppercase text-stone-400">Services</p>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-serif text-3xl md:text-4xl font-medium text-stone-900 leading-snug tracking-tight">
          How I work with clients.
        </h2>
        <p class="mt-4 text-stone-500 text-[17px] leading-relaxed">
          Available for fractional engagements, advisory retainers, and project-based work.
          I also take full-time roles when the fit is right.
        </p>
      </div>
    </div>

    <div class="space-y-16 md:space-y-20">
      {services.map((service) => (
        <div class="grid md:grid-cols-12 gap-8 md:gap-16">
          <div class="md:col-span-4">
            <span class="text-sm font-medium text-stone-400">{service.number}</span>
            <h3 class="mt-2 font-serif text-2xl font-medium text-stone-900 leading-snug">
              {service.title}
            </h3>
          </div>
          <div class="md:col-span-8">
            <p class="text-stone-600 text-[17px] leading-relaxed">
              {service.description}
            </p>
            <ul class="mt-6 space-y-3">
              {service.outcomes.map((outcome) => (
                <li class="flex items-start gap-3 text-stone-600 text-[15px]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-stone-400 shrink-0" />
                  {outcome}
                </li>
              ))}
            </ul>
            <p class="mt-6 text-sm text-stone-500 italic border-l-2 border-stone-300 pl-4">
              {service.proof}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
