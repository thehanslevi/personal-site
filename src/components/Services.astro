---
const services = [
  {
    number: '01',
    color: 'coral',
    accentBg: 'bg-coral',
    accentLight: 'bg-coral-light',
    accentText: 'text-coral',
    accentBorder: 'border-coral',
    title: 'Strategic accounts and customer success',
    description:
      'Senior relationship leadership for complex, high-touch client environments. I own accounts, align stakeholders, and drive adoption, retention, and long-term value.',
    outcomes: [
      'Executive stakeholder management and account ownership',
      'Onboarding, adoption strategy, and value realization',
      'Cross-functional delivery across technical and non-technical teams',
      'Sensitive client conversations, expectation management, and renewals',
    ],
    proof: '95%+ client retention over 8 years across 20+ engagements on four continents.',
  },
  {
    number: '02',
    color: 'teal',
    accentBg: 'bg-teal',
    accentLight: 'bg-teal-light',
    accentText: 'text-teal',
    accentBorder: 'border-teal',
    title: 'Program management and operations',
    description:
      'Standing up new programs, managing cross-functional portfolios, and designing operating rhythms. From AI initiative governance to philanthropic grantmaking to innovation programming.',
    outcomes: [
      'Portfolio management and operating rhythm design',
      'AI governance, responsible AI frameworks, and initiative tracking',
      'Program design, launch, and scaling across complex organizations',
      'Performance tracking, reporting, and executive briefings',
    ],
    proof: '200+ GenAI initiatives managed. 36% improvement in portfolio execution efficiency at Fortune 100 scale.',
  },
  {
    number: '03',
    color: 'gold',
    accentBg: 'bg-gold',
    accentLight: 'bg-gold-light',
    accentText: 'text-gold',
    accentBorder: 'border-gold',
    title: 'Fundraising, partnerships, and stakeholder strategy',
    description:
      'Capital raises, partnership development, donor engagement, and board-level strategic planning. Especially for mission-driven organizations, family offices, and foundations.',
    outcomes: [
      'Fundraising strategy and execution',
      'Partnership development and ecosystem building',
      'Board and executive-level scenario and strategic planning',
      'Impact measurement, reporting, and investor communications',
    ],
    proof: '$7M+ raised for a new institutional initiative. $500M AUM fund advised on portfolio construction and exits.',
  },
  {
    number: '04',
    color: 'violet',
    accentBg: 'bg-violet',
    accentLight: 'bg-violet-light',
    accentText: 'text-violet',
    accentBorder: 'border-violet',
    title: 'Arts and cultural producing',
    description:
      'Producing, programming, and operational leadership for live events, festivals, film, and theater. I bring the same strategic rigor to creative projects that I bring to enterprise work.',
    outcomes: [
      'Festival, conference, and event production and programming',
      'Documentary and narrative film producing',
      'Artist and creative community engagement',
      'Communications, marketing, and audience development for cultural organizations',
    ],
    proof: 'Produced documentary film and theater across the southeastern U.S. Designed and hosted conferences, events, and festivals for arts and social impact organizations.',
  },
]
---

<section id="services" class="py-24 md:py-32 relative overflow-hidden">
  <!-- subtle geometric background -->
  <div class="absolute inset-0 geo-pattern pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 md:gap-16 mb-16 md:mb-20">
      <div class="md:col-span-4">
        <div class="flex items-center gap-3 mb-1">
          <span class="w-3 h-3 rounded-sm bg-gold rotate-45"></span>
          <p class="text-sm font-medium tracking-widest uppercase text-base-400">Services</p>
        </div>
      </div>
      <div class="md:col-span-8">
        <h2 class="font-serif text-3xl md:text-4xl font-medium text-base-900 leading-snug tracking-tight">
          Let's collaborate.
        </h2>
        <p class="mt-4 text-base-500 text-[17px] leading-relaxed">
          Available for advisory retainers, board service, fractional engagements, and project-based work.
        </p>
      </div>
    </div>

    <div class="space-y-12 md:space-y-0 md:grid md:grid-cols-2 md:gap-8">
      {services.map((service) => (
        <div class={`group relative p-8 rounded-2xl border border-base-200 bg-base-50 hover:border-transparent hover:shadow-lg transition-all duration-300`}>
          <div class={`absolute top-0 left-8 right-8 h-[3px] ${service.accentBg} rounded-b-full opacity-0 group-hover:opacity-100 transition-opacity duration-300`}></div>

          <div class="flex items-center gap-3 mb-4">
            <span class={`flex items-center justify-center w-8 h-8 rounded-lg ${service.accentLight} text-xs font-semibold ${service.accentText}`}>
              {service.number}
            </span>
            <h3 class="font-serif text-xl font-medium text-base-900 leading-snug">
              {service.title}
            </h3>
          </div>

          <p class="text-base-600 text-[15px] leading-relaxed mb-5">
            {service.description}
          </p>

          <ul class="space-y-2.5 mb-6">
            {service.outcomes.map((outcome) => (
              <li class="flex items-start gap-2.5 text-base-600 text-[14px]">
                <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${service.accentBg} shrink-0 opacity-60`} />
                {outcome}
              </li>
            ))}
          </ul>

          <p class={`text-[13px] text-base-500 italic border-l-2 ${service.accentBorder} pl-3 opacity-70`}>
            {service.proof}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
