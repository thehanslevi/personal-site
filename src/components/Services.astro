  {
    number: '01',
    title: 'Strategic accounts and customer success',
    description:
      'Senior relationship leadership for complex, high-touch client environments. I own accounts, align stakeholders, and drive adoption, retention, and long-term value.',
    outcomes: [
      'Executive stakeholder management and account ownership',
      'Onboarding, adoption strategy, and value realization',
      'Cross-functional delivery across technical and non-technical teams',
      'Sensitive client conversations, expectation management, and renewals',
    ],
    proof: '95%+ client retention over 8 years across 20+ engagements on four continents.',
  },
  {
    number: '02',
    title: 'Program management and operations',
    description:
      'Standing up new programs, managing cross-functional portfolios, and designing operating rhythms. From AI initiative governance to philanthropic grantmaking to innovation programming.',
    outcomes: [
      'Portfolio management and operating rhythm design',
      'AI governance, responsible AI frameworks, and initiative tracking',
      'Program design, launch, and scaling across complex organizations',
      'Performance tracking, reporting, and executive briefings',
    ],
    proof: '200+ GenAI initiatives managed. 36% improvement in portfolio execution efficiency at Fortune 100 scale.',
  },
  {
    number: '03',
    title: 'Fundraising, partnerships, and stakeholder strategy',
    description:
      'Capital raises, partnership development, donor engagement, and board-level strategic planning. Especially for mission-driven organizations, family offices, and foundations.',
    outcomes: [
      'Fundraising strategy and execution',
      'Partnership development and ecosystem building',
      'Board and executive-level scenario and strategic planning',
      'Impact measurement, reporting, and investor communications',
